<script>
  import Granim from 'granim';

  new Granim({
    element: '#canvas-image-blending',
    direction: 'radial',
    isPausedWhenNotInView: true,
    image: {
      source: '/profile/pptesty.png',
      blendingMode: 'destination-atop',
    },
    states: {
      'default-state': {
        gradients: [
          ['#000000', '#1EAEDB'],
          ['#000000', '#9412A5'],
          ['#000000', '#1E6AE1'],
          ['#000000', '#1EAEDB'],
        ],
        transitionSpeed: 8000,
      },
    },
  });
</script>

<style>
  #hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 100px 0 60px;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 64px;
    flex: 1;
  }

  /* ── Left ── */
  .hero-left {
    flex: 1;
    min-width: 0;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .hero-name {
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 32px;
    color: var(--fg);
  }

  /* Glitch effect — sacred, improved */
  .glitch-name {
    display: inline-block;
    position: relative;
    color: var(--fg);
    cursor: default;
  }

  .glitch-name::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    white-space: nowrap;
    opacity: 0;
    color: var(--accent);
  }

  .glitch-name:hover {
    animation: glitch 0.8s steps(1, end) forwards;
  }
  .glitch-name:hover::after {
    animation: glitch-reveal 0.8s steps(1, end) forwards;
  }

  @keyframes glitch {
    0%   { transform: translate(0); color: inherit; }
    10%  { transform: translate(-2px, 2px); color: #ff00ff; }
    20%  { transform: translate(2px, -2px); color: #00ffff; }
    30%  { transform: translate(-2px, -2px); color: #ffff00; }
    40%  { transform: translate(2px, 2px); color: #ff00ff; }
    50%  { transform: translate(-2px, 2px); color: #00ffff; }
    60%  { transform: translate(0); color: inherit; }
    100% { transform: translate(0); color: transparent; }
  }

  @keyframes glitch-reveal {
    0%  { opacity: 0; }
    60% { opacity: 0; transform: translate(2px, -2px); }
    100%{ opacity: 1; transform: translate(0); }
  }

  /* ── Roles ── */
  .hero-roles {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 40px;
  }

  .role-link {
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 1.8vw, 1.25rem);
    color: var(--muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    background-image: linear-gradient(to right, #ffff00 0, #ffff00 100%);
    background-position: 0 -0.05em;
    background-size: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.4s var(--ease), color 0.3s var(--ease);
    padding-bottom: 2px;
  }

  .role-link:hover {
    background-size: 100% 100%;
    color: #000;
  }

  .role-bullet {
    color: var(--accent);
    transition: color 0.3s var(--ease);
  }

  .role-link:hover .role-bullet {
    color: #000;
  }

  /* ── Socials ── */
  .hero-socials {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    color: var(--muted);
    opacity: 0.6;
    transition: opacity 0.25s var(--ease), transform 0.25s var(--ease), color 0.25s var(--ease);
  }

  .social-link:hover {
    opacity: 1;
    color: var(--fg);
    transform: translateY(-3px);
  }

  .social-link img { display: block; filter: brightness(0) invert(1); }

  /* ── Right / profile ── */
  .hero-right {
    flex-shrink: 0;
  }

  .profile-ring {
    position: relative;
    width: clamp(260px, 28vw, 380px);
    height: clamp(260px, 28vw, 380px);
  }

  /* Rotating accent ring */
  .profile-ring::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: conic-gradient(
      var(--accent) 0deg,
      transparent 60deg,
      transparent 180deg,
      #9412A5 200deg,
      transparent 260deg,
      transparent 360deg
    );
    animation: spin-ring 8s linear infinite;
    opacity: 0.7;
  }

  /* Glow behind ring */
  .profile-ring::after {
    content: '';
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes spin-ring {
    to { transform: rotate(360deg); }
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.9; }
  }

  .profile-canvas {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: block;
  }

  /* ── Scroll hint ── */
  .hero-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding-bottom: 32px;
    opacity: 0.35;
  }

  .hero-scroll-hint span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--fg), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 1; transform: scaleY(1); transform-origin: top; }
    50% { opacity: 0.4; transform: scaleY(0.5); transform-origin: top; }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #hero {
      padding: 80px 0 0;
      justify-content: flex-start;
      min-height: 100svh;
    }

    .hero-inner {
      flex: 0 0 auto;
      flex-direction: column-reverse;
      gap: 28px;
      text-align: center;
    }

    .hero-roles { align-items: center; }
    .hero-socials { justify-content: center; }

    .profile-ring {
      width: 120px;
      height: 120px;
    }

    .hero-scroll-hint {
      margin-top: auto;
      padding-bottom: 32px;
    }

    .glitch-name:hover { animation: none; }
    .glitch-name:hover::after { animation: none; }
  }
</style>
