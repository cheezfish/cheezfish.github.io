  <a class="header-logo" href="/">cheez<span>fish</span></a>
  <nav>
    <ul class="header-nav">
      <li><a href="#about">About</a></li>
      <li><a href="#work">Work</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>
</header>

<section id="hero">
  <div class="hero-inner wrapper">
    <div class="hero-left">
      <p class="hero-eyebrow">Based in London</p>
      <h1 class="hero-name">
        Hi, this is<br>
        <span class="glitch-name" data-text="Cheezfish">Imran</span>
      </h1>
      <div class="hero-roles">
        <a href="https://drive.google.com/file/d/1g0FspV63qIispoSWriU93KmdQ6_0O1P2/view?usp=sharing" class="role-link" target="_blank" rel="noopener">
          <span class="role-bullet">—</span> Roboticist
