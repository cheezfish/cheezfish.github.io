type Project = typeof projects[0];

function Card({ title, img, url, tag }: Project) {
  return `
    <a href="${url}" class="card" target="_blank" rel="noopener" aria-label="${title}">
      <img class="card__img" src="${img}" alt="${title}" loading="lazy">
      <div class="card__overlay">
        <span class="card__tag">${tag}</span>
        <p class="card__title">${title}</p>
      </div>
    </a>
  `;
}
---

<section id="work">
  <div class="wrapper">

    <div class="projects-block reveal">
      <p class="section-label">Projects</p>
      <div class="bento bento--projects" set:html={projects.map(p => Card(p)).join('')} />
    </div>

    <hr class="divider section-gap" />

    <div class="projects-block reveal">
      <p class="section-label">Clients</p>
      <div class="bento clients-grid" set:html={clients.map(p => Card(p)).join('')} />
    </div>

    <hr class="divider section-gap" />

    <div class="projects-block reveal">
      <p class="section-label">Past Projects</p>
      <div class="bento past-grid" set:html={pastProjects.map(p => Card(p)).join('')} />
    </div>

  </div>
</section>

<style>
  #work {
    padding: 40px 0 96px;
  }

  .projects-block {
    padding: 56px 0;
  }

  .section-gap {
    margin: 0;
  }

  /* Past projects: 2-col to feel more considered */
  .past-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 560px) {
    #work { padding: 24px 0 56px; }
    .projects-block { padding: 32px 0; }
    .past-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
