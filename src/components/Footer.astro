---
---

<footer id="footer">
  <div class="wrapper">
    <hr class="divider">
    <div class="footer-inner">

      <div class="footer-book">
        <p class="footer-eyebrow">Let's talk</p>
        <div class="book-links">
          <a class="btn" href="https://zcal.co/thisisimran/brief" target="_blank" rel="noopener">Book 30 mins</a>
          <a class="btn" href="https://zcal.co/thisisimran/session" target="_blank" rel="noopener">Book 60 mins</a>
        </div>
      </div>

      <div class="footer-right">
        <div class="footer-socials">
          <a href="https://wa.me/+447972303813" target="_blank" rel="noopener" class="footer-social" aria-label="WhatsApp">
            <img src="/icons/whatsapp.png" alt="" width="20" height="20">
          </a>
          <a href="tel:+447972303813" class="footer-social" aria-label="Call">
            <img src="/icons/phone.png" alt="" width="20" height="20">
          </a>
          <a href="https://t.me/+447972303813" target="_blank" rel="noopener" class="footer-social" aria-label="Telegram">
            <img src="/icons/telegram.png" alt="" width="20" height="20">
          </a>
        </div>

        <p class="footer-meta">
          <a href="/classic" class="footer-archive-link">v2 ↗</a>
          &nbsp;·&nbsp;
          cheezfish &copy; {new Date().getFullYear()}
        </p>
      </div>

    </div>
  </div>
</footer>

<style>
  #footer {
    padding: 64px 0 48px;
  }

  .divider {
    margin-bottom: 48px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    flex-wrap: wrap;
  }

  .footer-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .book-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 20px;
  }

  .footer-socials {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .footer-social {
    display: flex;
    align-items: center;
    opacity: 0.5;
    transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
  }

  .footer-social:hover {
    opacity: 1;
    transform: translateY(-3px);
  }

  .footer-social img {
    filter: brightness(0) invert(1);
    display: block;
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .footer-archive-link {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }

  .footer-archive-link:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .footer-right { align-items: flex-start; }
  }
</style>
